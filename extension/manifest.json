{
  "manifest_version": 3,
  "name": "BGB Content Intelligence",
  "version": "1.0.0",
  "description": "Pull LinkedIn analytics into the BGB Content Engine. Learns what's working.",
  "permissions": ["tabs", "storage", "scripting", "activeTab"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://my-app-gilt-eight-89.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BGB Content Intelligence"
  },
  "background": {
    "service_worker": "background.js"
  }
}
