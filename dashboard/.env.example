# ============================================================================
# REQUIRED — production
# ============================================================================

# Supabase (frontend + backend)
# Project URL + anon key are safe to expose. Service-role key is admin-bypass — server-only.
VITE_SUPABASE_URL=                    # https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=               # sb_publishable_... (or legacy eyJ... anon JWT)
SUPABASE_SERVICE_ROLE_KEY=            # SERVER-ONLY. Never expose. Used by /api/csv-imports-cron + invite admin.

# Claude API — powers /api/llm-insights, /api/llm-recommendations, /api/csv-detect, /api/financial-*
# SERVER-ONLY. Don't prefix with VITE_.
ANTHROPIC_API_KEY=                    # sk-ant-api03-...

# Vercel Cron secret — Vercel auto-sets the Authorization header on cron requests using this value.
# Generate: openssl rand -hex 32
CRON_SECRET=

# ============================================================================
# OPTIONAL — feature-specific
# ============================================================================

# Google Sheets OAuth (only needed if you wire up direct-Drive integration; the published-CSV
# import doesn't need any Google credentials).
VITE_GOOGLE_OAUTH_CLIENT_ID=
VITE_GOOGLE_OAUTH_REDIRECT_URI=       # https://yourapp.com/api/google-oauth-callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
# AES-GCM key for encrypting OAuth tokens at rest.
INTEGRATION_ENCRYPTION_KEY=           # openssl rand -hex 32

# ============================================================================
# DEV ONLY — DO NOT SET IN PRODUCTION
# ============================================================================

# When both vars are set AND the build is NOT a production build, the app auto-signs-in this user
# on every page load (skips the magic-link step). Useful for local dogfooding.
# The app refuses to enable this in production builds even if these are set.
# VITE_DEV_AUTOLOGIN_EMAIL=
# VITE_DEV_AUTOLOGIN_PASSWORD=
